# Copie este arquivo para .env e ajuste os valores para o seu ambiente
# NUNCA commite o .env com valores reais

# ── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_USER=sinc
POSTGRES_PASSWORD=sinc
POSTGRES_DB=sinc

# Driver async (usado pelo FastAPI / SQLAlchemy em runtime)
DATABASE_URL=postgresql+asyncpg://sinc:sinc@localhost:5432/sinc
# Driver sync (usado pelo Alembic para migrações)
DATABASE_SYNC_URL=postgresql+psycopg2://sinc:sinc@localhost:5432/sinc

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ───────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-secrets-token-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Ambiente ─────────────────────────────────────────────────────────────────
# dev | staging | prod
ENVIRONMENT=dev
LOG_LEVEL=INFO
